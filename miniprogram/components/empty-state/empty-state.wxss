.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #888888;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #CCCCCC;
}
