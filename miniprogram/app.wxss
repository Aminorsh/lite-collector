/* @import 'tdesign-miniprogram/common/style/index.wxss'; */
/* Global Styles */
page {
  --color-primary: #4A90D9;
  --color-primary-light: #84abd6;
  --color-primary-dark: #3A7BC8;
  --color-success: #07C160;
  --color-warning: #FFA500;
  --color-danger: #FA5151;
  --color-text: #333333;
  --color-text-secondary: #888888;
  --color-text-placeholder: #CCCCCC;
  --color-bg: #F6F6F6;
  --color-bg-white: #FFFFFF;
  --color-border: #E5E5E5;
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;
  --font-size-sm: 24rpx;
  --font-size-base: 28rpx;
  --font-size-lg: 32rpx;
  --font-size-xl: 36rpx;
  --font-size-xxl: 44rpx;
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;

  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: var(--font-size-base);
  color: var(--color-text);
  background-color: var(--color-bg);
  box-sizing: border-box;
}

/* Utility classes */
.container {
  padding: var(--spacing-lg);
}

.text-center {
  text-align: center;
}

.text-secondary {
  color: var(--color-text-secondary);
}

.text-sm {
  font-size: var(--font-size-sm);
}

.mt-sm { margin-top: var(--spacing-sm); }
.mt-md { margin-top: var(--spacing-md); }
.mt-lg { margin-top: var(--spacing-lg); }
.mb-sm { margin-bottom: var(--spacing-sm); }
.mb-md { margin-bottom: var(--spacing-md); }
.mb-lg { margin-bottom: var(--spacing-lg); }

.btn-primary {
  background-color: var(--color-primary);
  color: #FFFFFF;
  border: none;
  border-radius: var(--radius-md);
  padding: var(--spacing-sm) var(--spacing-lg);
  font-size: var(--font-size-base);
  line-height: 2;
}

.btn-primary:active {
  background-color: var(--color-primary-dark);
}

/* 遮罩层 */
.splash-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

/* 整个小窗卡片 */
.splash-card {
  width: 72%;
  background: #fff;
  border-radius: 30rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 40rpx;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.15);
}

/* ========== 这里可以自由改图片宽高 ========== */
.splash-img {
  width: 100%;
  height: 320rpx; /* 改这个就能调图片高度 */
  display: block;
}

/* 文字区域 */
.splash-text-wrap {
  padding: 30rpx 24rpx;
  text-align: center;
}
.splash-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1d2129;
  display: block;
  margin-bottom: 12rpx;
}
.splash-desc {
  font-size: 26rpx;
  color: #86909c;
  line-height: 1.6;
}

/* 底部居中关闭 × 按钮 */
.close-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: #f2f3f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #666;
}

