.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f7fa;
}

/* 消息列表 */
.message-list {
  flex: 1;
  padding: 24rpx 32rpx;
  box-sizing: border-box;
}

.message-item {
  margin-bottom: 32rpx;
}

.message-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

/* 用户消息 - 右侧 */
.message-user {
  flex-direction: row-reverse;
}

.message-bubble-user {
  max-width: 70%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx 24rpx 8rpx 24rpx;
  padding: 20rpx 28rpx;
}

.message-bubble-ai {
  max-width: 70%;
  background: #ffffff;
  border-radius: 24rpx 24rpx 24rpx 8rpx;
  padding: 20rpx 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.message-text {
  font-size: 28rpx;
  color: #1d2129;
  line-height: 1.5;
  word-break: break-all;
}

.message-user .message-text {
  color: #ffffff;
}

/* 头像 */
.message-avatar-user,
.message-avatar-ai {
  width: 64rpx;
  height: 64rpx;
  flex-shrink: 0;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #e8f4ff;
}

.ai-avatar-icon {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

/* 输入框容器 */
.sender-container {
  padding: 16rpx 24rpx 32rpx;
  background: #ffffff;
  border-top: 1rpx solid #e7e7e7;
}

/* 空状态 */
.empty-chat {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 40rpx;

}

.empty-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #86909c;
  margin-top: 10rpx;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #86909c;
}

/* 隐藏加号按钮 */
.chat-container .t-chat-sender__prefix {
  display: none !important;
}

/* 如果上面不行，尝试更强的选择器 */
.t-chat-sender .t-icon-add {
  display: none !important;
}