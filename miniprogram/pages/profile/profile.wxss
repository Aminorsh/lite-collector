/* 全局容器 */
.container {
  padding: 24rpx;
  background-color: #f5f7fa;
  min-height: 100vh;
}

/* --------------------------
  1. 用户信息卡片（优化阴影、圆角）
--------------------------- */
.profile-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

/* 头像按钮 */
.avatar-btn {
  position: relative;
  background: transparent;
  border: none;
  padding: 0;
  margin: 0 0 16rpx;
}
.avatar-btn::after {
  border: none;
}

/* 头像样式 */
.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background-color: #f2f3f5;
  object-fit: cover;
}
.avatar-placeholder {
  background-color: #f2f3f5;
}

/* 上传中 loading */
.avatar-loading {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
}

/* 文字样式 */
.avatar-hint {
  font-size: 26rpx;
  color: #86898d;
  margin-bottom: 10rpx;
}
.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #1d2129;
  margin-bottom: 12rpx;
}
.user-id {
  font-size: 24rpx;
  color: #86909c;
}
.text-empty {
  color: #86909c;
}

/* --------------------------
  2. 菜单列表（TDesign 风格）
--------------------------- */
.menu-section {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}
.cell-value {
  font-size: 26rpx;
  color: #86909c;
}

/* --------------------------
  3. 编辑昵称面板
--------------------------- */
.edit-panel {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}
.edit-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d2129;
  margin-bottom: 20rpx;
}
.edit-input {
  margin-bottom: 24rpx;
}

/* 按钮组 */
.edit-actions {
  display: flex;
  gap: 20rpx;
}
.edit-actions t-button {
  flex: 1;
}