/* 全局容器 */
.container {
  padding: 24rpx;
  background-color: #f5f7fa;
  min-height: 100vh;
}

/* --------------------------
  1. 用户信息卡片（优化阴影、圆角）
--------------------------- */
.profile-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

/* 头像按钮 */
.avatar-btn {
  position: relative;
  background: transparent;
  border: none;
  padding: 0;
  margin: 0 0 16rpx;
}
.avatar-btn::after {
  border: none;
}

/* 头像样式 */
.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background-color: #f2f3f5;
  object-fit: cover;
}
.avatar-placeholder {
  background-color: #f2f3f5;
}

/* 上传中 loading */
.avatar-loading {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
}

/* 文字样式 */
.avatar-hint {
  font-size: 26rpx;
  color: #86898d;
  margin-bottom: 10rpx;
}
.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #1d2129;
  margin-bottom: 12rpx;
}
.user-id {
  font-size: 24rpx;
  color: #86909c;
}
.text-empty {
  color: #86909c;
}

/* --------------------------
  2. 菜单列表（TDesign 风格）
--------------------------- */
.menu-section {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}
.cell-value {
  font-size: 26rpx;
  color: #86909c;
}

/* --------------------------
  3. 编辑昵称面板
--------------------------- */
.edit-panel {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}
.edit-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d2129;
  margin-bottom: 20rpx;
}
.edit-input {
  margin-bottom: 24rpx;
}

/* 按钮组 */
.edit-actions {
  display: flex;
  gap: 20rpx;
}
.edit-actions t-button {
  flex: 1;
}

/* --------------------------
  每日一句卡片 带动态滚动小球背景
--------------------------- */
.quote-card {
  /* 原有底色保留 */
  background: rgb(255, 255, 255);
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(141, 76, 76, 0.04);
 /* 让整个卡片开启呼吸动画 */
 animation: cardBreath 5s ease-in-out infinite;
 transform-origin: center center;
  /* 开启相对定位，放动画小球 */
  position: relative;
  overflow: hidden;
}

/* 整体卡片 呼吸缩放动画 */
@keyframes cardBreath {
  0% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.02);
  }
  100% {
    transform: scale(1);
  }
}

/* 2. 轻微上下悬浮 */
@keyframes cardFloat {
  0% {
    transform: translateY(0rpx);
  }
  100% {
    transform: translateY(-8rpx);
  }
}

/* 新建：背景滚动小球 */
.quote-card::before {
  content: '';
  position: absolute;
  top: 30%;
  width: 80rpx;
  height: 80rpx;
  background: rgb(0, 77, 17);
  /* background: linear-gradient(135deg, #fcff43, #7c0bec); */
  border-radius: 50%;
  opacity: 0.15;
  /* 绑定滚动动画 */
  animation: ballMove 8s ease-in-out infinite alternate;
}

/* 定义小球左右滚动动画 */
@keyframes ballMove {
  0% {
    left: -40rpx;
  }
  100% {
    left: calc(100% - 40rpx);
  }
}

.quote-icon {
  font-size: 48rpx;
  width: 60rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea15, #764ba215);
  border-radius: 50%;
  /* 层级高于背景小球 */
  position: relative;
  z-index: 2;
}

.quote-content {
  flex: 1;
  /* 文字层级在上，不被小球遮挡 */
  position: relative;
  z-index: 2;
}

.quote-text {
  font-size: 32rpx;
  font-weight: 150;
  color: #1d2129;
  line-height: 1.5;
  display: block;
  font-style: italic;
  text-align: left;
}

/* 底部广告位容器 */
.ad-container {
  position: relative;
  width: 100%;
  margin-top: 40rpx;
  border-radius: 24rpx;
  overflow: hidden;
  aspect-ratio: 16 / 9;
  background: #f2f3f5;
}

/* 轮播容器 */
.ad-swiper {
  width: 100%;
  height: 100%;
}

/* 广告图片铺满 */
.ad-img {
  width: 100%;
  height: 100%;
}

/* 广告位招租文字遮罩 */
.ad-text {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  background: rgba(0, 0, 0, 0.55);
  padding: 12rpx 32rpx;
  border-radius: 12rpx;
  letter-spacing: 4rpx;
  z-index: 10;
}

/* AI 聊天圆形按钮 */
.ai-chat-btn {
  position: fixed;
  right: 40rpx;
  bottom: 50rpx;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgb(255, 255, 255);
  z-index: 100;
  transition: all 0.3s ease;
}

.ai-chat-btn:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 16rpx rgb(139, 157, 233);
}

/* 脉冲动画 - 吸引注意 */
.ai-pulse {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: rgb(193, 193, 197);
  animation: pulse 1.5s ease-out infinite;
  z-index: -1;
}

@keyframes pulse {
  0% {
    transform: scale(1);
    opacity: 0.6;
  }
  100% {
    transform: scale(1.6);
    opacity: 0;
  }
}
.ai-icon-img {
  width: 70rpx;
  height: 70rpx;
}