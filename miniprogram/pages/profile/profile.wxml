<view class="container">
  <!-- 1. 用户信息卡片（TDesign 风格） -->
  <view class="profile-card" wx:if="{{userInfo}}">
    <!-- 头像上传按钮 -->
    <button
      class="avatar-btn"
      open-type="chooseAvatar"
      bindchooseavatar="onChooseAvatar"
    >
      <image
        class="avatar"
        src="{{userInfo.avatar_url || '/assets/icons/1.png'}}"
        mode="aspectFill"
      />
      <!-- 上传中 loading -->
      <t-loading wx:if="{{uploading}}" class="avatar-loading" size="24" theme="white" />
    </button>

    <view class="avatar-hint">
      {{uploading ? '上传中...' : '点击更换头像'}}
    </view>

    <view class="user-name">{{userInfo.nickname || '微信用户'}}</view>
    <view class="user-id">ID: {{userInfo.id}}</view>
  </view>

  <!-- 未登录状态 -->
  <view class="profile-card" wx:else>
    <view class="avatar-wrapper">
      <view class="avatar avatar-placeholder"></view>
    </view>
    <view class="user-name text-empty">未登录</view>
  </view>

  <view class="quote-card">
    <view class="quote-icon">🤪</view>
    <view class="quote-content">
      <text class="quote-text">{{todayQuote}}</text>
      <!-- <text class="quote-author">—— {{quoteAuthor}}</text> -->
    </view>
  </view>

  <!-- 2. 修改昵称菜单（TDesign List） -->
  <view class="menu-section" wx:if="{{userInfo}}">
    <t-cell
      title="修改昵称"
      arrow
      bindtap="onEditNickname"
    >
      <view slot="right">
        <text class="cell-value">{{userInfo.nickname || '未设置'}}</text>
      </view>
    </t-cell>
  </view>

  <!-- 3. 修改昵称面板（TDesign 美化） -->
  <view class="edit-panel" wx:if="{{editing}}">
    <view class="edit-title">修改昵称</view>

    <!-- TDesign 输入框 -->
    <t-input
      value="{{editNickname}}"
      placeholder="请输入新昵称"
      maxlength="20"
      bind:change="onNicknameInput"
      class="edit-input"
    />

    <!-- TDesign 按钮组 -->
    <view class="edit-actions">
      <t-button
        variant="light"
        bindtap="onCancelEdit"
      >
        取消
      </t-button>
      <t-button
        theme="light"
        bindtap="onSaveNickname"
        disabled="{{saving}}"
        loading="{{saving}}"
      >
        {{saving ? '保存中...' : '保存'}}
      </t-button>
    </view>
  </view>
</view>

