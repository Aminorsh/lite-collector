<view class="container">
  <!-- 1. AI 任务横幅 -->
  <view class="job-banner-list" wx:if="{{pendingJobs.length > 0}}">
    <view
      class="job-banner {{item.inFlight ? 'job-banner-active' : (item.status === 3 ? 'job-banner-failed' : 'job-banner-done')}}"
      wx:for="{{pendingJobs}}"
      wx:key="id"
      data-index="{{index}}"
      bindtap="onJobTap"
    >
      <view class="job-banner-spinner" wx:if="{{item.inFlight}}" />
      <text class="job-banner-title">{{item.title}}</text>
      <view
        class="job-banner-dismiss"
        wx:if="{{!item.inFlight}}"
        catchtap="onJobDismiss"
        data-index="{{index}}"
      >×</view>
    </view>
  </view>

  <!-- 2. 搜索栏（TDesign） -->
  <t-search
    placeholder="搜索表单标题"
    value="{{query}}"
    bind:change="onQueryInput"
    shape="round"
    class="search-box"
  />

  <!-- 3. 排序 + 状态标签 -->
  <view class="filter-row">
    <t-picker
      value="{{sortIndex}}"
      range="{{sortOptions}}"
      range-key="label"
      bind:change="onSortChange"
    >
      <view slot="trigger">
        <t-button
          variant="text"
          icon="filter"
          size="small"
        >
          {{sortOptions[sortIndex].label}}
        </t-button>
      </view>
    </t-picker>

    <view class="status-tabs">
      <view
        class="status-tab {{status === item.value ? 'active' : ''}}"
        wx:for="{{statusTabs}}"
        wx:key="value"
        data-value="{{item.value}}"
        bindtap="onStatusTap"
      >
        <text>{{item.label}}</text>
      </view>
    </view>
  </view>

  <!-- 4. 加载状态（TDesign） -->
  <t-loading
    wx:if="{{loading}}"
    class="loading-wrap"
    tip="加载中..."
  />

  <!-- 5. 空状态（TDesign） -->
  <t-empty
    wx:if="{{!loading && forms.length === 0}}"
    text="暂无表单"
    description="点击右下角按钮创建第一个表单"
    icon="file"
    class="empty-wrap"
  />

  <!-- 6. 表单列表 -->
  <view class="form-list" wx:if="{{!loading && forms.length > 0}}">
    <view
      class="form-card"
      wx:for="{{forms}}"
      wx:key="id"
      bindtap="onFormTap"
      data-id="{{item.id}}"
    >
      <view class="form-card-header">
        <text class="form-title">{{item.title}}</text>
        <t-tag
          size="small"
          variant="light"
          shape="round"
          color="{{item.status == 1 ? 'blue' : item.status == 2 ? 'grey' : 'warning'}}"
        >
          {{item.status == 1 ? '已发布' : item.status == 2 ? '已归档' : '草稿'}}
        </t-tag>
      </view>

      <view class="form-card-desc" wx:if="{{item.description}}">
        <text class="text-desc">{{item.description}}</text>
      </view>

      <view class="form-card-footer">
        <t-icon name="date" size="14" />
        <text class="text-time">{{item.updatedAtText}}</text>
      </view>
    </view>
  </view>

  <!-- 7. 悬浮创建按钮（修复点击） -->
  <!-- FAB -->
  <view class="fab" bindtap="onCreateTap">
    <text class="fab-icon">+</text>
  </view>
</view>