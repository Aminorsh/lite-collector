<view class="container">
  <!-- Filter bar -->
  <view class="filter-bar">
    <view class="search-row">
      <input
        class="search-input"
        placeholder="搜索表单标题"
        value="{{query}}"
        bindinput="onQueryInput"
        confirm-type="search"
      />
      <picker
        class="sort-picker"
        range="{{sortOptions}}"
        range-key="label"
        value="{{sortIndex}}"
        bindchange="onSortChange"
      >
        <view class="sort-label">
          <text class="text-sm">{{sortOptions[sortIndex].label}}</text>
          <text class="sort-caret">▾</text>
        </view>
      </picker>
    </view>
    <view class="status-tabs">
      <view
        class="status-tab {{status === item.value ? 'active' : ''}}"
        wx:for="{{statusTabs}}"
        wx:key="value"
        data-value="{{item.value}}"
        bindtap="onStatusTap"
      >
        <text>{{item.label}}</text>
      </view>
    </view>
  </view>

  <!-- Loading -->
  <view class="loading-state" wx:if="{{loading}}">
    <text class="text-secondary">加载中...</text>
  </view>

  <!-- Empty -->
  <empty-state
    wx:if="{{!loading && forms.length === 0}}"
    icon="📋"
    text="暂无表单"
    hint="点击右下方按钮创建第一个表单"
  />

  <!-- Form list -->
  <view class="form-list" wx:if="{{!loading && forms.length > 0}}">
    <view
      class="form-card"
      wx:for="{{forms}}"
      wx:key="id"
      bindtap="onFormTap"
      data-id="{{item.id}}"
    >
      <view class="form-card-header">
        <text class="form-title">{{item.title}}</text>
        <status-badge status="{{item.status}}" type="form" />
      </view>
      <view class="form-card-desc" wx:if="{{item.description}}">
        <text class="text-secondary text-sm">{{item.description}}</text>
      </view>
      <view class="form-card-footer">
        <text class="text-secondary text-sm">{{item.updatedAtText}}</text>
      </view>
    </view>
  </view>

  <!-- FAB -->
  <view class="fab" bindtap="onCreateTap">
    <text class="fab-icon">+</text>
  </view>
</view>
