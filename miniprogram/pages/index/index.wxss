/* 全局容器 */
.container {
  padding: 24rpx;
  background-color: #ffffff;
  min-height: 100vh;
}

/* --------------------------
  1. AI 任务横幅（优化圆角、间距）
--------------------------- */
.job-banner-list {
  margin-bottom: 24rpx;
}
.job-banner {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(42, 68, 105, 0.05);
}
.job-banner-active {
  background-color: #e8f4ff;
  color: #1677ff;
}
.job-banner-done {
  background-color: #e6ffee;
  color: #00b42a;
}
.job-banner-failed {
  background-color: #fff1f0;
  color: #f53f3f;
}
.job-banner-spinner {
  width: 24rpx;
  height: 24rpx;
  border: 3rpx solid rgba(22, 119, 255, 0.2);
  border-top-color: #1677ff;
  border-radius: 50%;
  margin-right: 16rpx;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.job-banner-dismiss {
  font-size: 32rpx;
  opacity: 0.6;
  margin-left: 16rpx;
}

/* --------------------------
  2. 搜索框（间距优化）
--------------------------- */
.search-box {
  margin-bottom: 25rpx;
}

/* --------------------------
  3. 过滤栏：排序 + 标签栏
--------------------------- */
.filter-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}
.status-tabs {
  display: flex;
  gap: 12rpx;
}
.status-tab {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  font-size: 25rpx;
  background-color: #fff;
  color: #0e0f0f;
  border: 2rpx solid #dadee0;
}
.status-tab.active {
  background-color: #05517e;
  color: #fff;
  border-color: #828488;
}

/* --------------------------
  4. 加载 / 空状态
--------------------------- */
.loading-wrap {
  margin-top: 200rpx;
  text-align: center;
}
.empty-wrap {
  margin-top: 180rpx;
}

/* --------------------------
  5. 表单卡片（质感升级）
--------------------------- */
.form-list {
  padding-bottom: 160rpx;
}
.form-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}
.form-card:active {
  opacity: 0.9;
  transform: scale(0.98);
  transition: 0.2s;
}
.form-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.form-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #303133;
  max-width: 70%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.form-card-desc {
  margin-bottom: 20rpx;
}
.text-desc {
  font-size: 26rpx;
  color: #86909c;
  line-height: 1.5;
}
.form-card-footer {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  color: #86909c;
  font-size: 24rpx;
  gap: 8rpx;
}
.text-time {
  color: #2d3b37;
}

/* --------------------------
  6. 悬浮按钮（位置微调）
--------------------------- */
/* .custom-fab {
  bottom: 120rpx !important;
} */

/* FAB */
.fab {
  background-color: #acccaa !important;
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgb(243, 243, 243);
}

.fab:active {
  background-color: var(--color-primary-dark);
}

.fab-icon {
  color: #FFFFFF;
  font-size: 56rpx;
  line-height: 1;
  margin-top: -4rpx;
}