/* 全局容器 - 浅灰色背景 */
.container {
  padding: 24rpx;

  background-color: #f8f9fa;  /* 改为浅灰色背景 */
  min-height: 100vh;
}

/* --------------------------
  1. AI 任务横幅
--------------------------- */
.job-banner-list {
  margin-bottom: 24rpx;
}
.job-banner {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}
.job-banner-active {
  background-color: #e8f4ff;
  color: #1677ff;
}
.job-banner-done {
  background-color: #e6ffee;
  color: #00b42a;
}
.job-banner-failed {
  background-color: #fff1f0;
  color: #f53f3f;
}
.job-banner-spinner {
  width: 24rpx;
  height: 24rpx;
  border: 3rpx solid rgba(22, 119, 255, 0.2);
  border-top-color: #1677ff;
  border-radius: 50%;
  margin-right: 16rpx;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.job-banner-dismiss {
  font-size: 32rpx;
  opacity: 0.6;
  margin-left: 16rpx;
}

/* --------------------------
  2. 搜索框
--------------------------- */
.search-box {
  margin-bottom: 32rpx;
}
/* TDesign 搜索框样式覆盖 - 匹配图示 */
.search-box .t-search__input {
  background-color: #ffffff !important;
  border: 1px solid #e4e7ed !important;
  border-radius: 32rpx !important;
}

/* --------------------------
  3. 过滤栏：排序 + 标签栏
--------------------------- */
.filter-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}
.status-tabs {
  display: flex;
  gap: 16rpx;
}
.status-tab {
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  background-color: #ffffff;
  color: #2c3e50;  /* 深蓝色文字 */
  border: 1px solid #dcdfe6;
  transition: all 0.2s;
}
.status-tab.active {
  background-color: #2c3e50;  /* 深蓝色背景 */
  color: #ffffff;  /* 白色文字 */
  border-color: #2c3e50;
}

/* --------------------------
  4. 加载 / 空状态
--------------------------- */
.loading-wrap {
  margin-top: 200rpx;
  text-align: center;
}
.empty-wrap {
  margin-top: 180rpx;
}

/* --------------------------
  5. 表单卡片
--------------------------- */
.form-list {
  padding-bottom: 160rpx;
}
.form-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s;
}
.form-card:active {
  opacity: 0.95;
  transform: scale(0.99);
}
.form-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.form-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #303133;
  max-width: 70%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.form-card-desc {
  margin-bottom: 24rpx;
}
.text-desc {
  font-size: 26rpx;
  color: #909399;
  line-height: 1.5;
}
.form-card-footer {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
}
.text-time {
  font-size: 24rpx;
  color: #909399;
}
/* TDesign 标签样式覆盖 - 匹配图示的标签颜色 */
.form-card .t-tag {
  border-radius: 24rpx !important;
  font-size: 24rpx !important;
  padding: 6rpx 16rpx !important;
}

/* --------------------------
  6. 悬浮按钮 - 深蓝色匹配整体风格
--------------------------- */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background-color: #587e64;  /* 深蓝色，与激活标签色一致 */
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(44, 62, 80, 0.3);
  transition: all 0.2s;
}

.fab:active {
  background-color: #1e2a36;  /* 按下时更深 */
  transform: scale(0.95);
}

.fab-icon {
  color: #ffffff;
  font-size: 60rpx;
  line-height: 1;
  margin-top: -4rpx;
}

/* 遮罩层 */
.splash-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

/* 整个小窗卡片 */
.splash-card {
  width: 72%;
  background: #ffffff;
  border-radius: 60rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 40rpx;

  /* 外层大阴影：做主悬浮 */
  box-shadow: 0 50rpx 50rpx rgba(0, 0, 0, 0.25),
              0 8rpx 50rpx rgba(0, 0, 0, 0.08);
  /* 内层内阴影：凹陷质感 */
  box-shadow: inset 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

/* ========== 这里可以自由改图片宽高 ========== */
.splash-img {
  object-fit: contain;
  width: 100%;
  height: 400rpx; /* 改这个就能调图片高度 */
  display: block;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
  opacity: 0.85;
}

/* 文字区域 */
.splash-text-wrap {
  padding: 30rpx 24rpx;
  text-align: center;
}
.splash-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1d2129;
  display: block;
  margin-bottom: 20rpx;
}
.splash-desc {
  font-size: 26rpx;
  color: #777b80;
  line-height: 1.6;
}

/* 底部居中关闭 × 按钮 */
.close-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: #f2f3f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: rgb(0, 0, 0);
}
