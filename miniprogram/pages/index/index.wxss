.loading-state {
  display: flex;
  justify-content: center;
  padding-top: 200rpx;
}

/* Filter bar */
.filter-bar {
  background-color: var(--color-bg-white);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-md);
}

.search-row {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.search-input {
  flex: 1;
  background-color: var(--color-bg);
  border-radius: var(--radius-md);
  padding: 14rpx 20rpx;
  font-size: var(--font-size-md);
}

.sort-picker {
  flex-shrink: 0;
}

.sort-label {
  background-color: var(--color-bg);
  border-radius: var(--radius-md);
  padding: 14rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.sort-caret {
  font-size: 20rpx;
  color: var(--color-text-secondary);
}

.status-tabs {
  display: flex;
  gap: var(--spacing-xs);
  margin-top: var(--spacing-md);
}

.status-tab {
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  font-size: var(--font-size-sm);
  background-color: var(--color-bg);
  color: var(--color-text-secondary);
}

.status-tab.active {
  background-color: var(--color-primary);
  color: #ffffff;
}

/* Form list */
.form-list {
  padding-bottom: 160rpx;
}

.form-card {
  background-color: var(--color-bg-white);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
}

.form-card:active {
  opacity: 0.8;
}

.form-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-sm);
}

.form-title {
  font-size: var(--font-size-lg);
  font-weight: 600;
  flex: 1;
  margin-right: var(--spacing-sm);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.form-card-desc {
  margin-bottom: var(--spacing-sm);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.form-card-footer {
  display: flex;
  justify-content: flex-end;
}

/* FAB */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(74, 144, 217, 0.4);
}

.fab:active {
  background-color: var(--color-primary-dark);
}

.fab-icon {
  color: #FFFFFF;
  font-size: 56rpx;
  line-height: 1;
  margin-top: -4rpx;
}
