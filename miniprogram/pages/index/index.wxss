/* Pending AI jobs banner */
.job-banner-list {
  margin-bottom: var(--spacing-md);
}

.job-banner {
  display: flex;
  align-items: center;
  padding: var(--spacing-md) var(--spacing-lg);
  border-radius: var(--radius-md);
  margin-bottom: var(--spacing-sm);
  font-size: var(--font-size-base);
}

.job-banner-active {
  background-color: #E8F1FB;
  color: #2A5FAF;
}

.job-banner-done {
  background-color: #E6F6EB;
  color: #1F7A3C;
}

.job-banner-failed {
  background-color: #FBE9E9;
  color: #B02A37;
}

.job-banner:active {
  opacity: 0.85;
}

.job-banner-title {
  flex: 1;
}

.job-banner-spinner {
  width: 24rpx;
  height: 24rpx;
  border: 3rpx solid rgba(42, 95, 175, 0.25);
  border-top-color: #2A5FAF;
  border-radius: 50%;
  margin-right: var(--spacing-sm);
  animation: job-banner-spin 0.8s linear infinite;
}

@keyframes job-banner-spin {
  to { transform: rotate(360deg); }
}

.job-banner-dismiss {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  line-height: 1;
  color: inherit;
  opacity: 0.6;
  margin-left: var(--spacing-sm);
}

.job-banner-dismiss:active {
  opacity: 1;
}

.loading-state {
  display: flex;
  justify-content: center;
  padding-top: 200rpx;
}

/* Filter bar */
.filter-bar {
  background-color: var(--color-bg-white);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-md);
}

.search-row {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.search-input {
  flex: 1;
  background-color: var(--color-bg);
  border-radius: var(--radius-md);
  padding: 14rpx 20rpx;
  font-size: var(--font-size-md);
}

.sort-picker {
  flex-shrink: 0;
}

.sort-label {
  background-color: var(--color-bg);
  border-radius: var(--radius-md);
  padding: 14rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.sort-caret {
  font-size: 20rpx;
  color: var(--color-text-secondary);
}

.status-tabs {
  display: flex;
  gap: var(--spacing-xs);
  margin-top: var(--spacing-md);
}

.status-tab {
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  font-size: var(--font-size-sm);
  background-color: var(--color-bg);
  color: var(--color-text-secondary);
}

.status-tab.active {
  background-color: var(--color-primary);
  color: #ffffff;
}

/* Form list */
.form-list {
  padding-bottom: 160rpx;
}

.form-card {
  background-color: var(--color-bg-white);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
}

.form-card:active {
  opacity: 0.8;
}

.form-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-sm);
}

.form-title {
  font-size: var(--font-size-lg);
  font-weight: 600;
  flex: 1;
  margin-right: var(--spacing-sm);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.form-card-desc {
  margin-bottom: var(--spacing-sm);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.form-card-footer {
  display: flex;
  justify-content: flex-end;
}

/* FAB */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(74, 144, 217, 0.4);
}

.fab:active {
  background-color: var(--color-primary-dark);
}

.fab-icon {
  color: #FFFFFF;
  font-size: 56rpx;
  line-height: 1;
  margin-top: -4rpx;
}
