/* 全局 */
.container {
  padding: 24rpx;
  background-color: #f5f7fa;
  min-height: 100vh;
}

/* 区块 */
.section-1 {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
  height: 400rpx;
  /* 纵向滚动 */
  overflow-y: auto;
  /* 可选：隐藏滚动条（微信端） */
  -webkit-overflow-scrolling: touch;
}
/* 隐藏滚动条（可选） */
.section-1::-webkit-scrollbar {
  display: none;
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1d2129;
  margin-bottom: 20rpx;
}
.form-title{
  font-size: 28rpx;
  font-weight: 500;
  color: #4e5155;
  margin-bottom: 20rpx;
}

.description-title{
  font-size: 28rpx;
  font-weight: 500;
  color: #4e5155;
  margin-bottom: 20rpx;
}

.field-count {
  font-size: 26rpx;
  color: #86909c;
}

/* 输入框间距 */
.input-item {
  margin-bottom: 20rpx;
}

.section-2 {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* 字段卡片 */
.field-card {
  background: #f7f8fa;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.field-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
/* .field-header .t-tag {
  font-size: 26rpx !important; /* 你想多大改多大 */
/* } */ 
.field-actions {
  display: flex;
  gap: 8rpx;
}

/* 开关行 */
.toggle-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
  font-size: 28rpx;
}

/* 选项区域 */
.options-section {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #e5e6eb;
}

.options-title {
  font-size: 26rpx;
  color: #86909c;
  margin-bottom: 16rpx;
}

.option-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.option-input {
  flex: 1;
}

.add-option-btn {
  color: #1677ff !important;
  margin-top: 8rpx;
}

/* 添加字段按钮 */
.add-field-btn {
  margin-bottom: 24rpx;
}

/* 保存区域 */
.save-area {
  padding-bottom: 80rpx;
}

/* 弹窗内容 */
.dialog-content {
  max-height: 50vh;
}

.dialog-item {
  padding: 24rpx;
  text-align: center;
  font-size: 28rpx;
  border-bottom: 1rpx solid #f2f3f5;
}

.dialog-item:active {
  background: #f5f7fa;
}

.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  align-items: flex-end;
}

.picker-panel {
  width: 100%;
  background: #fff;
  border-radius: 16rpx 16rpx 0 0;
  max-height: 60vh;
  display: flex;
  flex-direction: column;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 500;
}

.picker-cancel {
  font-size: 28rpx;
  color: #4A90D9;
}

.picker-content {
  flex: 1;
  overflow-y: auto;
}

.picker-item {
  padding: 30rpx;
  text-align: center;
  font-size: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}