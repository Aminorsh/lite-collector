/* 全局容器 */
.container {
  padding: 24rpx;
  background-color: #f5f7fa;
  min-height: 100vh;
}

/* --------------------------
  加载状态
--------------------------- */
.loading-center {
  display: flex;
  justify-content: center;
  padding-top: 200rpx;
}

/* --------------------------
  表单详情卡片（优化质感）
--------------------------- */
.detail-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1d2129;
  flex: 1;
  margin-right: 16rpx;
}

.detail-desc {
  font-size: 28rpx;
  color: #4e5969;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.detail-meta {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  color: #86909c;
  font-size: 24rpx;
  margin-bottom: 16rpx;
}

.detail-stats {
  padding-top: 20rpx;
  border-top: 2rpx solid #f2f3f5;
  color: #86909c;
  font-size: 24rpx;
}

/* --------------------------
  按钮区域
--------------------------- */
.action-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* --------------------------
  任务横幅（优化动画与圆角）
--------------------------- */
.job-banner {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.job-banner-active {
  background-color: #e8f4ff;
  color: #1677ff;
}

.job-banner-done {
  background-color: #e6ffee;
  color: #00b42a;
}

.job-banner-failed {
  background-color: #fff1f0;
  color: #f53f3f;
}

.job-banner-title {
  flex: 1;
}

.job-banner-spinner {
  width: 24rpx;
  height: 24rpx;
  border: 3rpx solid rgba(22, 119, 255, 0.2);
  border-top-color: #1677ff;
  border-radius: 50%;
  margin-right: 16rpx;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.job-banner-dismiss {
  font-size: 32rpx;
  opacity: 0.6;
  margin-left: 16rpx;
}

