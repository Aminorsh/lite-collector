.loading-center {
  display: flex;
  justify-content: center;
  padding-top: 200rpx;
}

.detail-card {
  background-color: var(--color-bg-white);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-lg);
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: var(--spacing-md);
}

.detail-title {
  font-size: var(--font-size-xl);
  font-weight: bold;
  flex: 1;
  margin-right: var(--spacing-sm);
}

.detail-desc {
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
  margin-bottom: var(--spacing-md);
  line-height: 1.6;
}

.detail-meta {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: var(--spacing-sm);
}

.detail-stats {
  padding-top: var(--spacing-sm);
  border-top: 2rpx solid var(--color-border);
}

/* Action buttons */
.action-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.action-btn-full {
  width: 100%;
  border-radius: var(--radius-md);
  font-size: var(--font-size-base);
  line-height: 2.4;
  background-color: var(--color-bg-white);
  color: var(--color-text);
  border: 2rpx solid var(--color-border);
}

.action-btn-full:active {
  opacity: 0.8;
}

.action-primary {
  background-color: var(--color-primary);
  color: #FFFFFF;
  border-color: var(--color-primary);
}

.action-primary:active {
  background-color: var(--color-primary-dark);
}

.action-warn {
  color: var(--color-warning);
  border-color: var(--color-warning);
}

/* Job banner (shared shape; colors per state) */
.job-banner {
  display: flex;
  align-items: center;
  padding: var(--spacing-md) var(--spacing-lg);
  border-radius: var(--radius-md);
  margin-bottom: var(--spacing-md);
  font-size: var(--font-size-base);
}

.job-banner-active {
  background-color: #E8F1FB;
  color: #2A5FAF;
}

.job-banner-done {
  background-color: #E6F6EB;
  color: #1F7A3C;
}

.job-banner-failed {
  background-color: #FBE9E9;
  color: #B02A37;
}

.job-banner:active {
  opacity: 0.85;
}

.job-banner-title {
  flex: 1;
}

.job-banner-spinner {
  width: 24rpx;
  height: 24rpx;
  border: 3rpx solid rgba(42, 95, 175, 0.25);
  border-top-color: #2A5FAF;
  border-radius: 50%;
  margin-right: var(--spacing-sm);
  animation: job-banner-spin 0.8s linear infinite;
}

@keyframes job-banner-spin {
  to { transform: rotate(360deg); }
}

.job-banner-dismiss {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  line-height: 1;
  color: inherit;
  opacity: 0.6;
  margin-left: var(--spacing-sm);
}

.job-banner-dismiss:active {
  opacity: 1;
}
