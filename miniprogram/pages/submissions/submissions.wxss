/* ==================== 全局容器 ==================== */
.container {
  width: 100%;
  max-width: 100%;
  padding: 24rpx 32rpx;
  box-sizing: border-box;
}

/* ==================== Loading ==================== */
.loading-center {
  display: flex;
  justify-content: center;
  padding-top: 200rpx;
}

/* ==================== Tabs ==================== */
.tab-bar {
  display: flex;
  background-color: var(--color-bg-white);
  border-radius: var(--radius-lg);
  margin-bottom: var(--spacing-md);
  overflow: hidden;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 32rpx;
  color: var(--color-text-secondary);
}

.tab-active {
  color: var(--color-primary);
  font-weight: 600;
  border-bottom: 6rpx solid var(--color-primary);
}

/* ==================== Stats ==================== */
.stats-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-md);
  padding: 0 8rpx;
}

.anomaly-count {
  color: var(--color-danger);
  font-weight: 600;
}

/* ==================== List view ==================== */
.submission-list {
  width: 100%;
}

.submission-card {
  width: 100%;
  background-color: var(--color-bg-white);
  border-radius: var(--radius-md);
  padding: 36rpx 40rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.submission-card:active {
  opacity: 0.8;
}

.submission-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.submission-id {
  font-size: 36rpx;
  font-weight: 600;
}

/* ==================== Overview table ==================== */
.overview-wrap {
  width: 100%;
  background-color: var(--color-bg-white);
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.table-container {
  display: flex;
  width: 100%;
}

.table-fixed {
  flex-shrink: 0;
  width: 160rpx;
  border-right: 2rpx solid var(--color-border);
}

.table-scroll {
  flex: 1;
  width: calc(100% - 160rpx);
}

.table-scroll-inner {
  display: flex;
  flex-direction: column;
}

.table-header-row,
.table-data-row {
  display: flex;
}

.table-th {
  width: 320rpx;
  min-width: 320rpx;
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  background-color: var(--color-bg);
  border-bottom: 2rpx solid var(--color-border);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  box-sizing: border-box;
}

.table-fixed .table-th {
  width: 160rpx;
  min-width: 160rpx;
  text-align: center;
}

.table-td {
  width: 320rpx;
  min-width: 320rpx;
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  border-bottom: 2rpx solid var(--color-border);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  box-sizing: border-box;
}

.table-fixed .table-td {
  width: 160rpx;
  min-width: 160rpx;
  font-weight: 600;
  text-align: center;
}

.anomaly-row {
  background-color: rgba(250, 81, 81, 0.08);
}

.anomaly-row:active {
  background-color: rgba(250, 81, 81, 0.15);
}