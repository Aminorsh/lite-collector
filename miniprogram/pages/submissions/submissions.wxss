.loading-center {
  display: flex;
  justify-content: center;
  padding-top: 200rpx;
}

/* Tabs */
.tab-bar {
  display: flex;
  background-color: var(--color-bg-white);
  border-radius: var(--radius-lg);
  margin-bottom: var(--spacing-md);
  overflow: hidden;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: var(--spacing-sm) 0;
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
}

.tab-active {
  color: var(--color-primary);
  font-weight: 600;
  border-bottom: 4rpx solid var(--color-primary);
}

/* Stats */
.stats-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-md);
}

.anomaly-count {
  color: var(--color-danger);
  font-weight: 600;
}

/* List view */
.submission-card {
  background-color: var(--color-bg-white);
  border-radius: var(--radius-md);
  padding: var(--spacing-md) var(--spacing-lg);
  margin-bottom: var(--spacing-sm);
}

.submission-card:active {
  opacity: 0.8;
}

.submission-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-xs);
}

.submission-id {
  font-size: var(--font-size-lg);
  font-weight: 600;
}

/* Overview table */
.overview-wrap {
  background-color: var(--color-bg-white);
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.table-container {
  display: flex;
}

.table-fixed {
  flex-shrink: 0;
  width: 120rpx;
  border-right: 2rpx solid var(--color-border);
}

.table-scroll {
  flex: 1;
}

.table-scroll-inner {
  display: flex;
  flex-direction: column;
}

.table-header-row, .table-data-row {
  display: flex;
}

.table-th {
  width: 240rpx;
  min-width: 240rpx;
  padding: 16rpx 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  background-color: var(--color-bg);
  border-bottom: 2rpx solid var(--color-border);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  box-sizing: border-box;
}

.table-fixed .table-th {
  width: 120rpx;
  min-width: 120rpx;
}

.table-td {
  width: 240rpx;
  min-width: 240rpx;
  padding: 16rpx 20rpx;
  font-size: 24rpx;
  border-bottom: 2rpx solid var(--color-border);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  box-sizing: border-box;
}

.table-fixed .table-td {
  width: 120rpx;
  min-width: 120rpx;
  font-weight: 600;
  text-align: center;
}

.anomaly-row {
  background-color: rgba(250, 81, 81, 0.08);
}

.anomaly-row:active {
  background-color: rgba(250, 81, 81, 0.15);
}
