<view class="container">
  <!-- 1. 加载状态（TDesign 美化） -->
  <t-loading
    wx:if="{{loading}}"
    class="loading-center"
    tip="加载中..."
  />

  <block wx:if="{{!loading}}">
    <!-- 2. 顶部标题与操作栏（TDesign 风格卡片） -->
    <view class="header-card">
      <text class="header-title">底表数据管理</text>
      <text class="sub-title">共 {{rows.length}} 条记录</text>
      
      <view class="header-actions">
        <!-- 导入数据按钮（浅色系） -->
        <t-button block theme="light" bindtap="onShowImport">
          导入数据
        </t-button>
        <!-- 清空数据按钮（浅红） -->
        <t-button 
          block 
          theme="danger" 
          bindtap="onClearAll" 
          wx:if="{{rows.length > 0}}"
        >
          清空数据
        </t-button>
      </view>
    </view>

    <!-- Import panel -->
    <view class="import-panel" wx:if="{{showImport}}">
      <view class="import-hint">
        <text class="text-sm">请粘贴 JSON 数组格式的数据，每项包含 row_key 和 data 字段：</text>
        <text class="text-sm text-secondary mt-sm">[{{"{"}} "row_key":"EMP001", "data":{{"{"}} "f_001":"张三" {{"}"}} {{"}"}}, ...]</text>
      </view>
      <textarea
        class="import-textarea"
        placeholder='[{"row_key":"EMP001","data":{"f_001":"张三","f_002":"技术部"}}]'
        value="{{importText}}"
        bindinput="onImportInput"
        maxlength="50000"
      />
      <view class="import-actions">
        <t-button variant="light" bindtap="onCancelImport">取消</t-button>
        <t-button
          theme="light"
          bindtap="onDoImport"
          disabled="{{importing}}"
          loading="{{importing}}"
          >
        {{importing ? '导入中...' : '确认导入'}}
        </t-button>
      </view>
    </view>

    <!-- Data list -->
    <empty-state
      wx:if="{{rows.length === 0 && !showImport}}"
      text="暂无底表数据"
      hint="点击「导入数据」添加预填充数据"
    />

    <view class="data-list" wx:if="{{rows.length > 0}}">
      <view class="data-card" wx:for="{{rows}}" wx:key="id">
        <view class="data-key">{{item.row_key}}</view>
        <view class="data-preview text-secondary text-sm">{{item.preview}}</view>
      </view>
    </view>
  </block>
</view>
