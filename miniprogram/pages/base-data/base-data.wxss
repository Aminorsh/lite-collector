
/* 加载居中 */
.loading-center {
  display: flex;
  justify: center;
  padding-top: 200rpx;
}

/* 顶部卡片 */
.header-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* 标题 */
.header-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1d2129;
  margin-bottom: 8rpx;
  display: block;
}

/* 副标题 */
.sub-title {
  font-size: 26rpx;
  color: #86909c;
  margin-bottom: 24rpx;
  display: block;
}

/* 按钮组 */
.header-actions {
  display: flex;
  gap: 16rpx;
}
.header-actions t-button {
  flex: 1;
}
/* Import panel */
.import-panel {
  background-color: var(--color-bg-white);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
}

.import-hint {
  display: flex;
  flex-direction: column;
  margin-bottom: var(--spacing-md);
}

.import-textarea {
  width: 100%;
  min-height: 300rpx;
  padding: var(--spacing-md);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  font-size: var(--font-size-sm);
  font-family: monospace;
  box-sizing: border-box;
  margin-bottom: var(--spacing-md);
}

/* 按钮组 */
.import-actions {
  display: flex;
  gap: 16rpx;
}
.import-actions t-button {
  flex: 1;
}

/* Data list */
.data-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.data-card {
  background-color: var(--color-bg-white);
  border-radius: var(--radius-md);
  padding: var(--spacing-md) var(--spacing-lg);
}

.data-key {
  font-size: var(--font-size-base);
  font-weight: 600;
  margin-bottom: 4rpx;
}

.data-preview {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
