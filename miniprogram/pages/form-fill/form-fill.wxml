<view class="container">
  <!-- 1. 加载状态（TDesign 优化） -->
  <t-loading
    wx:if="{{loading}}"
    class="loading-center"
    tip="加载中..."
  />

  <!-- 2. 错误状态 -->
  <view class="error-state" wx:if="{{errorMsg}}">
    <t-empty
      description="{{errorMsg}}"
      type="error"
    />
  </view>

  <!-- 3. 提交成功页面（TDesign 风格） -->
  <view class="success-full" wx:if="{{!loading && !errorMsg && submitSuccess}}">
    <t-result
      type="success"
      title="提交成功"
      description="感谢您的填写"
    />
    <t-button
      class="back-btn"
      block
      theme="primary"
      bindtap="onGoBack"
    >
      返回
    </t-button>
  </view>

  <!-- 4. 表单填写区域 -->
  <block wx:if="{{!loading && !errorMsg && !submitSuccess}}">
    <!-- 表单标题卡片 -->
    <view class="form-card">
      <text class="form-title">{{formTitle}}</text>
      <text class="form-desc" wx:if="{{formDesc}}">{{formDesc}}</text>
    </view>

    <!-- 自动预填提示条 -->
    <view class="prefill-banner" wx:if="{{prefilled}}">
      <t-icon name="info-circle" color="#1677ff" size="12" />
      <text class="prefill-text">已根据你上次的填写自动预填</text>
      <t-button
        variant="text"
        size="medium"
        theme="primary"
        bindtap="onClearPrefill"
      >
        清空
      </t-button>
    </view>

    <!-- 表单内容 -->
    <view class="form-body">
      <form-renderer
        fields="{{fields}}"
        values="{{values}}"
        errors="{{errors}}"
        bind:change="onFieldChange"
      />
    </view>

    <!-- 提交按钮 -->
    <view class="submit-area">
      <t-button
        block
        theme="primary"
        bindtap="onSubmit"
        disabled="{{submitting}}"
        loading="{{submitting}}"
      >
        {{submitting ? '提交中...' : '提交'}}
      </t-button>
    </view>
  </block>
</view>