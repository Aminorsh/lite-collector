<view class="container">
  <!-- Loading -->
  <view class="loading-center" wx:if="{{loading}}">
    <text class="text-secondary">加载中...</text>
  </view>

  <!-- Error -->
  <view class="error-state" wx:if="{{errorMsg}}">
    <text class="text-secondary">{{errorMsg}}</text>
  </view>

  <!-- Submission success -->
  <view class="success-full" wx:if="{{!loading && !errorMsg && submitSuccess}}">
    <text class="success-full-icon">✓</text>
    <text class="success-full-title">提交成功</text>
    <text class="success-full-hint">感谢您的填写</text>
    <button class="btn-primary mt-lg" bindtap="onGoBack">返回</button>
  </view>

  <!-- Fill mode (with auto-prefill) -->
  <block wx:if="{{!loading && !errorMsg && !submitSuccess}}">
    <view class="form-card">
      <text class="form-title">{{formTitle}}</text>
      <text class="form-desc" wx:if="{{formDesc}}">{{formDesc}}</text>
    </view>

    <!-- Prefill banner -->
    <view class="prefill-banner" wx:if="{{prefilled}}">
      <text class="prefill-text">已根据你上次的填写自动预填</text>
      <text class="prefill-clear" bindtap="onClearPrefill">清空</text>
    </view>

    <view class="form-body">
      <form-renderer
        fields="{{fields}}"
        values="{{values}}"
        errors="{{errors}}"
        bind:change="onFieldChange"
      />
    </view>
    <view class="submit-area">
      <button class="btn-primary submit-btn" bindtap="onSubmit" disabled="{{submitting}}">
        {{submitting ? '提交中...' : '提交'}}
      </button>
    </view>
  </block>
</view>
